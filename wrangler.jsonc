{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sosh-social",
  "compatibility_date": "2026-02-08",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sosh-production",
      "database_id": ""
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "sosh-media"
    }
  ]
}